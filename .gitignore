# Virtual environment
.venv/
venv/
env/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Distribution and build
build/
dist/
*.egg-info/
.eggs/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# IDE
.vscode/
.idea/
*.swp
*.swo

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Streamlit
.streamlit/secrets.toml

# Data files - committed selectively
data/raw/
data/interim/
*.csv
*.xlsx
*.xls

# Most model files are too large to commit, but the production XGBoost
# model needs to live in the repo so Streamlit Cloud can load it.
# Allow xgboost_model.joblib through; exclude any other joblib dumps.
models/*.joblib
!models/xgboost_model.joblib

# Environment variables
.env
.env.local

# Logs
*.log
logs/
